---
import FormButton from "./FormButton.astro";
---

<div>
  <!-- SVG clipPaths independientes para cada Breakpoint con anchos calibrados para dar medidas de píxeles fijos -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <!-- Breakpoint 1: Móvil (tarjeta de 340px) -> Muesca de ~60% = exactamente 204px (para botón de 200px) -->
      <clipPath id="notchMobile" clipPathUnits="objectBoundingBox">
        <path
          d="M 0.08, 0 
             H 0.92 
             C 0.98, 0, 1, 0.02, 1, 0.08 
             V 0.92 
             C 1, 0.98, 0.98, 1, 0.92, 1 
             H 0.83 
             C 0.82, 1, 0.81, 0.99, 0.81, 0.98 
             V 0.94 
             C 0.81, 0.93, 0.80, 0.92, 0.79, 0.92 
             H 0.21 
             L 0.19, 0.94
             V 0.98 
             C 0.19, 0.99, 0.18, 1, 0.17, 1 
             H 0.08 
             C 0.02, 1, 0, 0.98, 0, 0.92 
             V 0.08 
             C 0, 0.02, 0.02, 0, 0.08, 0 
             Z"
        ></path>
      </clipPath>

      <!-- Breakpoint 2: Tableta (tarjeta de 400px) -> Muesca de ~56% = exactamente 224px (para botón de 220px) -->
      <clipPath id="notchTablet" clipPathUnits="objectBoundingBox">
        <path
          d="M 0.08, 0 
             H 0.92 
             C 0.98, 0, 1, 0.02, 1, 0.08 
             V 0.92 
             C 1, 0.98, 0.98, 1, 0.92, 1 
             H 0.81 
             C 0.80, 1, 0.79, 0.99, 0.79, 0.98 
             V 0.945 
             C 0.79, 0.935, 0.78, 0.925, 0.77, 0.925 
             H 0.23 
             L 0.21, 0.945
             V 0.98 
             C 0.21, 0.99, 0.20, 1, 0.19, 1 
             H 0.08 
             C 0.02, 1, 0, 0.98, 0, 0.92 
             V 0.08 
             C 0, 0.02, 0.02, 0, 0.08, 0 
             Z"
        ></path>
      </clipPath>

      <!-- Breakpoint 3: Escritorio (tarjeta de 480px) -> Muesca de ~52% = exactamente 249.6px (para botón de 246px) -->
      <clipPath id="notchDesktop" clipPathUnits="objectBoundingBox">
        <path
          d="M 0.08, 0 
             H 0.92 
             C 0.98, 0, 1, 0.02, 1, 0.08 
             V 0.92 
             C 1, 0.98, 0.98, 1, 0.92, 1 
             H 0.79 
             C 0.78, 1, 0.77, 0.99, 0.77, 0.98 
             V 0.95 
             C 0.77, 0.94, 0.76, 0.93, 0.75, 0.93 
             H 0.26 
             L 0.23, 0.95
             V 0.99 
             C 0.23, 0.99, 0.22, 1, 0.21, 1 
             H 0.08 
             C 0.02, 1, 0, 0.98, 0, 0.92 
             V 0.08 
             C 0, 0.02, 0.02, 0, 0.08, 0 
             Z"
        ></path>
      </clipPath>
    </defs>
  </svg>
  <div class="form-wrapper">
    <!-- SVG overlay para dibujar el borde continuo y brillante para cada uno de los 3 Breakpoints -->
    <svg class="border-overlay" viewBox="0 0 1 1" preserveAspectRatio="none">
      <defs>
        <linearGradient id="borderGradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="rgba(255, 86, 86, 0.27)" />
          <stop offset="55%" stop-color="rgba(255, 86, 86, 0.27)" />
          <stop offset="100%" stop-color="rgba(255, 86, 86, 0.27)" />
        </linearGradient>
      </defs>
      <!-- Borde de Teléfono -->
      <path
        class="path-mobile"
        vector-effect="non-scaling-stroke"
        stroke="url(#borderGradient)"
        d="M 0.08, 0 H 0.92 C 0.98, 0, 1, 0.02, 1, 0.08 V 0.92 C 1, 0.98, 0.98, 1, 0.92, 1 H 0.83 C 0.82, 1, 0.81, 0.99, 0.81, 0.98 V 0.94 C 0.81, 0.93, 0.80, 0.92, 0.79, 0.92 H 0.21 L 0.19, 0.94 V 0.98 C 0.19, 0.99, 0.18, 1, 0.17, 1 H 0.08 C 0.02, 1, 0, 0.98, 0, 0.92 V 0.08 C 0, 0.02, 0.02, 0, 0.08, 0 Z"
      ></path>
      <!-- Borde de Tableta -->
      <path
        class="path-tablet"
        vector-effect="non-scaling-stroke"
        stroke="url(#borderGradient)"
        d="M 0.08, 0 H 0.92 C 0.98, 0, 1, 0.02, 1, 0.08 V 0.92 C 1, 0.98, 0.98, 1, 0.92, 1 H 0.81 C 0.80, 1, 0.79, 0.99, 0.79, 0.98 V 0.945 C 0.79, 0.935, 0.78, 0.925, 0.77, 0.925 H 0.23 L 0.21, 0.945 V 0.98 C 0.21, 0.99, 0.20, 1, 0.19, 1 H 0.08 C 0.02, 1, 0, 0.98, 0, 0.92 V 0.08 C 0, 0.02, 0.02, 0, 0.08, 0 Z"
      ></path>
      <!-- Borde de Escritorio -->
      <path
        class="path-desktop"
        vector-effect="non-scaling-stroke"
        stroke="url(#borderGradient)"
        d="M 0.08, 0 H 0.92 C 0.98, 0, 1, 0.02, 1, 0.08 V 0.92 C 1, 0.98, 0.98, 1, 0.92, 1 H 0.79 C 0.78, 1, 0.77, 0.99, 0.77, 0.98 V 0.95 C 0.77, 0.94, 0.76, 0.93, 0.75, 0.93 H 0.25 L 0.23, 0.95 V 0.98 C 0.23, 0.99, 0.22, 1, 0.21, 1 H 0.08 C 0.02, 1, 0, 0.98, 0, 0.92 V 0.08 C 0, 0.02, 0.02, 0, 0.08, 0 Z"
      ></path>
    </svg>

    <form class="contact-form" id="contactForm">
      <p class="form-description">
        Disponible para trabajos Frontend y Backend (proyectos, colaboraciones o
        consultas). Cuéntame tu objetivo y te respondo a la brevedad.
      </p>

      <div class="input-group">
        <label for="name">Nombre Completo</label>
        <input
          type="text"
          id="fullName"
          name="fullName"
          placeholder="Nombre completo"
        />
      </div>

      <div class="input-group">
        <label for="email">correo electronico</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="correo electronico"
        />
      </div>

      <div class="input-group">
        <label for="message">Mensaje hjk</label>
        <textarea
          id="message"
          name="message"
          placeholder="Cuéntame los detalles (mín. 20 caracteres)"
          minlength="20"></textarea>
      </div>
      
    </form>

    <!-- El botón de enviar va FUERA de la etiqueta <form> utilizando el componente personalizado FormButton.astro con submit nativo en tamaño small -->
    <div class="btn-enviar">
      <FormButton
        text="Enviar"
        form="contactForm"
        ariaLabel="Boton de enviar mensaje"
        width="100%"
        iconPosition="left"
        size="small"
      >
        <div style="width: 20px; height: 100%;"> 

          <svg xmlns="http://www.w3.org/2000/svg" version="1.1" class="pacman3351" viewBox="50 30 240 250" ><!--In order to externalize the SVG for use as an object, we have to put all the necessary styling inline here.--><style>.pacman3351-dot {
            fill: currentColor;
        }
        .pacman3351 {
          height: 100%;
        }
       
        .pacman3351-open,
        .pacman3351-mouth-top,
        .pacman3351-mouth-bottom {
            fill: currentColor;
        }

        .pacman3351-mouth-top,
        .pacman3351-mouth-bottom {
            animation-duration: 175ms;
            animation-timing-function: linear;
            animation-direction: alternate;
            animation-iteration-count: infinite;
            transform-origin: calc(300px/2) 150px; // center of circle
        }

        .pacman3351-mouth-top {
            animation-name: rotate3351-counterclockwise;
        }

        .pacman3351-mouth-bottom {
            animation-name: rotate3351-clockwise;
        }

        @keyframes rotate3351-counterclockwise {
            100% {
                transform: rotate(-30deg);
            }
        }

        @keyframes rotate3351-clockwise {
            100% {
                transform: rotate(30deg);
            }
        }


        

        </style><!--Create arcs covering 45°, so there's a little overlap with animations of 30°.--><path class="pacman3351-mouth-bottom" d="
        M 150,150
        L 220.4,221.0
        A 100 100 0 0 0 250,150
        Z"/><path class="pacman3351-mouth-top" d="
        M 150,150 
        L 220.4,79.0
        A 100 100 0 0 1 250,150
        Z"/><path class="pacman3351-open" d="
        M 150,150
        L 236.6,100
        A 100 100 0 1 0 236.6,200
        Z"/></svg>
        </div>
        
      </FormButton>
    </div>
    
  </div>
</div>
<script>
  import emailjs from "@emailjs/browser";

  const sendForm = (e: SubmitEvent) => {
    e.preventDefault(); // Evita el envío automático para manejarlo manualmente

    emailjs.send(
      import.meta.env.PUBLIC_EMAILJS_SERVICE_ID,
      import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID,
      {
        fullName: (document.querySelector("#fullName") as HTMLInputElement)
          .value,
        email: (document.querySelector("#email") as HTMLInputElement).value,
        message: (document.querySelector("#message") as HTMLTextAreaElement)
          .value,
      },
    );
  };
  emailjs.init(import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY);
  (document.querySelector("#contactForm") as HTMLFormElement).addEventListener(
    "submit",
    (e: SubmitEvent) => {
      console.log("Formulario enviado");
      e.preventDefault();
      // sendForm(e);
    },
  );
</script>
<style>
  /* Form wrapper con filtro drop-shadow continuo que calza con el clip-path */
  .form-wrapper {
    filter: drop-shadow(0 0 25px rgba(11, 30, 58, 0.158));
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .form-wrapper {
      width: 400px; /* Ancho exacto y fijo en tableta */
    }
  }

  @media (max-width: 599px) {
    .form-wrapper {
      width: 340px; /* Ancho exacto y fijo en móvil */
    }
  }

  @media (max-width: 350px) {
    .form-wrapper {
      width: 100%; /* Fluido solo en pantallas ultra pequeñas */
    }
  }
   

  .border-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .border-overlay path {
    fill: none;
    stroke-width: 0px;
  }

  /* Control de visibilidad del trazado de borde brillante para cada breakpoint */
  .path-mobile,
  .path-tablet,
  .path-desktop {
    display: none;
  }

  @media (max-width: 599px) {
    .path-mobile {
      display: block;
    }
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .path-tablet {
      display: block;
    }
  }

  @media (min-width: 901px) {
    .path-desktop {
      display: block;
    }
  }

  /* Formulario base con clip-path dinámico y los mismos efectos metal-glass de las cards */
  .contact-form {
    position: relative;
    z-index: 1;
    background: rgba(0, 0, 0, 0.247); /* Mismo fondo que la card de proyectos */
    backdrop-filter: blur(4px); /* Suave desenfoque idéntico */
    clip-path: url(#notchMobile); /* Móvil por defecto */
    padding: 3rem 2.5rem 6.5rem 2.5rem; /* Relleno inferior para dar espacio a la muesca */
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    transition: clip-path 0.3s ease;

    /* Efectos de sombras internas idénticos a .resume en Card.astro */
    box-shadow:
      0 4px 2px rgba(255, 86, 86, 0.27),
      inset 0 1px 5px rgba(255, 86, 86, 0.27),
      inset 0 -1px 40px rgba(255, 86, 86, 0.27),
      inset 0 1px 10px -20px rgba(255, 86, 86, 0.27);
    overflow: hidden;
  }

  /* Borde izquierdo con degradado idéntico al pseudoelemento de Card.astro */
  .contact-form::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(48, 19, 19, 0.8),
      transparent,
      rgba(185, 30, 30, 0.3)
    );
    pointer-events: none;
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .contact-form {
      clip-path: url(#notchTablet); /* Cambia a muesca de tableta */
    }
  }

  @media (min-width: 901px) {
    .contact-form {
      clip-path: url(#notchDesktop); /* Cambia a muesca de escritorio */
    }
  }

  .form-description {
    color: #ffffff;
    font-size: 1rem;
    line-height: 1.6;
    text-align: center;
    margin-bottom: 0.8rem;
    font-weight: 500;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: left;
  }

  .input-group label {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: capitalize;
    padding-left: 4px;
  }

  .input-group input,
  .input-group textarea {
    background: #ffffff00;
    color: #f0f0f0;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 14px 16px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.3s ease;
    width: 100%;
  }

  .input-group input::placeholder,
  .input-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
  }

  .input-group input:focus,
  .input-group textarea:focus {
    border-color: #ad1e3d; /* Color de foco azul brillante */
    outline: none;
    box-shadow: 0 0 12px rgba(211, 13, 13, 0.25);
  }

  .input-group textarea {
    height: 130px;
    resize: none;
  }

  /* Posicionamiento exacto y adaptable del componente FormButton.astro en el centro de la muesca */
  .btn-enviar {
    position: absolute;
    bottom: -17px; /* Altura de FormButton.astro en size small es de 56px, por lo que este margen lo posiciona perfecto en el centro de la muesca */
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    width: 255px; /* Ancho de botón fijo en escritorio */
  }

  /* Forzamos box-sizing border-box en el componente FormButton.astro para lograr centrado milimétrico */
  .btn-enviar :global(.form-button-wrapper),
  .btn-enviar :global(.form-button) {
    box-sizing: border-box !important;
  }

  @media (min-width: 600px) and (max-width: 900px) {
    .btn-enviar {
      width: 220px; /* Ancho de botón fijo en tableta */
      bottom: -16px; /* Se ajusta para el botón en tamaño small en tableta */
    }
  }

  @media (max-width: 599px) {
    .btn-enviar {
      width: 200px; /* Ancho de botón fijo en móvil */
      bottom: -8px; /* Se ajusta para el botón en tamaño small en móvil */
    }
  }
</style>
