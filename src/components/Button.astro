---
interface Props {
  iconPosition: "left" | "right";
  textSize?: "small" | "medium" | "large";
  text?: string;
  link: string;
  ariaLabel: string;
  width?: string;
  borderColor?: string;
}

let {
  iconPosition,
  textSize,
  text,
  link,
  ariaLabel,
  width = "76px",
  borderColor = "1a5ae9",
} = Astro.props;
const borderColorHover = "#" + borderColor + "ff"; // Agregamos transparencia al color de borde
borderColor = "#" + borderColor + "59"; // Agregamos transparencia al color de borde
---

<div
  class="button-wrapper"
  style={`--border-color-wrapper: ${borderColor}; --border-color-wrapper-hover: ${borderColorHover};`}
>
  <a
    class="button"
    href={link}
    target="_blank"
    aria-label={ariaLabel}
    style={`width: ${width};`}
  >
    <div class="content">
      {
        iconPosition === "left" ? (
          <div class="icon">
            <slot />
          </div>
        ) : null
      }
      {text && <span class={textSize || "medium"}>{text}</span>}
      {iconPosition === "right" ? <slot /> : null}
    </div>
  </a>
</div>

<style>
  .small {
    font-size: 1rem;
  }
  .medium {
    font-size: 1.25rem;
  }
  .large {
    font-size: 1.5rem;
  }
  .button:has(.small) {
    padding: 0.5rem;
  }
  .button:has(.medium) {
    padding: 1.5rem;
  }
  .button:has(.large) {
    padding: 2rem;
  }
  .button {
    display: flex;
    width: 76px;
    padding: 1.5rem;
    justify-content: center;
    align-items: center;
    border-radius: 12px;
    background: #151515;
    border: none;
    clip-path: polygon(
      10px 0,
      100% 0,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0 100%,
      0 10px
    );
    /* botones */

    /* box-shadow: 0 3px 11px var(--spread, 5px) #385eb259; */
    transition: box-shadow 0.3s ease-in-out;
  }
  .button-wrapper {
    padding: 3px;

    clip-path: polygon(
      10px 0,
      100% 0,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0 100%,
      0 10px
    );
    background-color: var(--border-color-wrapper, #385fb24d);
    border-radius: 12px;
    transition: background-color 0.3s ease-in-out;
  }

  .content {
    width: fit-content;
    transition: transform 0.3s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-weight: 600;
  }

  .button:hover .content {
    transform: scale(1.1);
  }

  .button-wrapper:has(.button:hover) {
    background-color: var(--border-color-wrapper-hover, #385fb2b0);
  }

  @media (max-width: 760px) {
    .button {
      width: 69px;
      height: 69px;
      padding: 20px;

      gap: 10px;
    }
  }
</style>
