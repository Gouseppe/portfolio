---
interface Props {
  iconPosition: "left" | "right";
  text?: string;
  ariaLabel: string;
  width?: string;
  form?: string;
  size?: "small" | "medium" | "large";
}

let {
  iconPosition,
  text,
  ariaLabel,
  width = "76px",
  form,
  size = "medium",
} = Astro.props;
---

<div class={`form-button-wrapper size-${size}`} style={`width: ${width};`}>
  <button
    class={`form-button size-${size}`}
    form={form}
    type="submit"
    aria-label={ariaLabel}
    style={`width: ${width};`}
  >
    <div class="content">
      {
        iconPosition === "left" && (
          <div class="icon">
            <slot />
            <div class="succesIcon" />
          </div>
        )
      }
      {text && <span>{text}</span>}
      {
        iconPosition === "right" && (
          <div class="icon">
            <slot />
          </div>
        )
      }
    </div>
  </button>
</div>

<style>
  /* Wrapper con los cortes poligonales idénticos y borde metálico */
  .form-button-wrapper {
    box-sizing: border-box;
    padding: 1.5px; /* Borde metálico muy fino */
    clip-path: polygon(
      10px 0,
      100% 0,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0 100%,
      0 10px
    );

    border-radius: 12px;
    transition:
      background-color 0.3s ease-in-out,
      box-shadow 0.3s ease-in-out;
  }

  /* Botón con fondo translúcido y sombras internas metálicas */
  .form-button {
    display: flex;
    box-sizing: border-box;
    justify-content: center;
    align-items: center;
    border-radius: 12px;
    background: rgba(
      0,
      0,
      0,
      0.247
    ); /* Mismo fondo translúcido que las cards */
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    clip-path: polygon(
      0 10px,
      10px 0,
      100% 0,
      100% calc(100% - 10px),
      calc(100% - 10px) 100%,
      0 100%
    );

    /* Inset shadows idénticos al panel .resume de las cards */
    box-shadow:
      inset 0 1px 10px rgba(129, 17, 17, 0.568),
      inset 0 -1px 10px rgba(148, 1, 1, 0.411),
      inset 0 0 20px -10px rgb(85, 9, 9);
    transition: background-color 0.3s ease-in-out;
  }

  /* Control de Altura y Padding por Prop de Size */

  /* 1. Small */
  .form-button.size-small {
    height: 56px;
    padding: 12px 20px;
  }

  .form-button.size-small .content {
    font-size: 1.1rem;
    gap: 8px;
  }

  /* 2. Medium (Default) */
  .form-button.size-medium {
    height: 76px;
    padding: 25px;
  }

  .form-button.size-medium .content {
    font-size: 1.5rem;
    gap: 10px;
  }

  /* 3. Large */
  .form-button.size-large {
    height: 96px;
    padding: 30px;
  }

  .form-button.size-large .content {
    font-size: 1.8rem;
    gap: 12px;
  }

  /* Contenido interno y animación */
  .content {
    width: fit-content;
    transition: transform 0.3s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: #ffffff;
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }

  /* Hover states */
  .form-button:hover .content {
    transform: scale(1.05);
  }

  .form-button:hover {
    background: rgba(
      0,
      0,
      0,
      0.35
    ); /* Fondo ligeramente más oscuro al pasar el cursor */
  }

  /* Focus states */
  .form-button:focus-visible {
    outline: none;
  }

  /* Responsivo para móviles */
  @media (max-width: 760px) {
    .form-button.size-small {
      height: 48px;
      padding: 10px;
    }

    .form-button.size-medium {
      height: 69px;
      padding: 20px;
    }

    .form-button.size-large {
      height: 85px;
      padding: 22px;
    }
  }
</style>
