---
import Button from "../components/Button.astro";
import { Mail, Linkedin, Github } from "@lucide/astro";
---

<section>
  <h2 class="title">Contact Me</h2>

  <!-- SVG clipPath con coordenadas relativas (objectBoundingBox) para ser 100% responsivo -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <clipPath id="notchShape" clipPathUnits="objectBoundingBox">
        <path
          d="M 0.08, 0 
             H 0.92 
             C 0.98, 0, 1, 0.02, 1, 0.08 
             V 0.92 
             C 1, 0.98, 0.98, 1, 0.92, 1 
             H 0.65 
             C 0.63, 1, 0.62, 0.85, 0.60, 0.85 
             H 0.40 
             C 0.38, 0.85, 0.37, 1, 0.35, 1 
             H 0.08 
             C 0.02, 1, 0, 0.98, 0, 0.92 
             V 0.08 
             C 0, 0.02, 0.02, 0, 0.08, 0 
             Z"
        ></path>
      </clipPath>
    </defs>
  </svg>

  <div class="form-wrapper">
    <!-- SVG overlay para dibujar el borde continuo y brillante de forma responsiva -->
    <svg class="border-overlay" viewBox="0 0 1 1" preserveAspectRatio="none">
      <path
        vector-effect="non-scaling-stroke"
        d="M 0.08, 0 
           H 0.92 
           C 0.98, 0, 1, 0.02, 1, 0.08 
           V 0.92 
           C 1, 0.98, 0.98, 1, 0.92, 1 
           H 0.65 
           C 0.63, 1, 0.62, 0.85, 0.60, 0.85 
           H 0.40 
           C 0.38, 0.85, 0.37, 1, 0.35, 1 
           H 0.08 
           C 0.02, 1, 0, 0.98, 0, 0.92 
           V 0.08 
           C 0, 0.02, 0.02, 0, 0.08, 0 
           Z"
      ></path>
    </svg>

    <form class="contact-form" action="#" method="POST">
      <p class="form-description">
        Disponible para trabajos Frontend y Backend (proyectos, colaboraciones o consultas). Cuéntame tu objetivo y te respondo a la brevedad.
      </p>

      <div class="input-group">
        <label for="name">Nombre Completo</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Nombre completo"
          required
        />
      </div>

      <div class="input-group">
        <label for="email">correo electronico</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="correo electronico"
          required
        />
      </div>

      <div class="input-group">
        <label for="message">Mensaje</label>
        <textarea
          id="message"
          name="message"
          placeholder="Cuéntame los detalles (mín. 20 caracteres)"
          minlength="20"
          required
        ></textarea>
      </div>

      <div class="btn-enviar">
        <button type="submit" class="submit-button" aria-label="Enviar mensaje">
          <span>Enviar</span>
          <Mail size={18} width={18} class="send-icon" />
        </button>
      </div>
    </form>
  </div>

  <div class="qr-code-wrapper">
    <div class="qr-code-container">
      <img
        src="https://api.qrserver.com/v1/create-qr-code/?size=160x160&color=ffffff&bgcolor=05010d&data=https://github.com/Gouseppe/portfolio/raw/main/public/Fernando_Guzman.pdf"
        alt="QR Code to view resume"
        class="qr-image"
      />
    </div>
    <div class="qr-label">Escanealo para ver mi CV</div>
  </div>

  <div class="buttons-wrapper">
    <Button
      text="LinkedIn"
      iconPosition="right"
      link="https://www.linkedin.com/in/fernando-guzm%C3%A1n-18177b313/"
      ariaLabel="Boton de linkedin"
      width="100%"
    >
      <Linkedin size={24} width={24} />
    </Button>
    <Button
      text="GitHub"
      iconPosition="left"
      link="https://github.com/Gouseppe"
      ariaLabel="Boton de github"
      width="100%"
    >
      <Github size={24} width={24} />
    </Button>
  </div>
</section>

<style>
  section {
    width: 100%;
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    grid-template-areas: 
      "title title" 
      "form  qr" 
      "form  buttons";
    gap: 40px;
    padding: 80px 20px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    font-size: var(--font-base);
    font-family: system-ui, sans-serif;
  }

  .title {
    grid-area: title;
    font-size: var(--font-title);
    font-weight: 700;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  /* Form wrapper con filtro drop-shadow continuo que calza con el clip-path */
  .form-wrapper {
    grid-area: form;
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    filter: drop-shadow(0 0 25px rgba(26, 90, 233, 0.25));
  }

  .border-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .border-overlay path {
    fill: none;
    stroke: rgba(107, 70, 255, 0.5); /* Color de borde brillante (accent-1) */
    stroke-width: 1.5px;
  }

  .contact-form {
    position: relative;
    z-index: 1;
    background: rgba(6, 8, 20, 0.85); /* Fondo oscuro translúcido */
    backdrop-filter: blur(12px);
    clip-path: url(#notchShape);
    padding: 3rem 2.5rem 6.5rem 2.5rem; /* Generoso relleno inferior para limpiar la muesca */
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    height: 100%;
    border-radius: 24px;
  }

  .form-description {
    color: #ffffff;
    font-size: 1rem;
    line-height: 1.6;
    text-align: center;
    margin-bottom: 0.8rem;
    font-weight: 500;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: left;
  }

  .input-group label {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: capitalize;
    padding-left: 4px;
  }

  .input-group input,
  .input-group textarea {
    background: #ffffff;
    color: #0f172a;
    border: 2px solid transparent;
    border-radius: 12px;
    padding: 14px 16px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.3s ease;
    width: 100%;
  }

  .input-group input::placeholder,
  .input-group textarea::placeholder {
    color: rgba(15, 23, 42, 0.5);
    font-weight: 400;
  }

  .input-group input:focus,
  .input-group textarea:focus {
    border-color: #1a5ae9; /* Color de foco azul brillante */
    outline: none;
    box-shadow: 0 0 12px rgba(26, 90, 233, 0.25);
  }

  .input-group textarea {
    height: 130px;
    resize: none;
  }

  .btn-enviar {
    position: absolute;
    bottom: 22px; /* Alineado perfectamente dentro del recorte de la muesca */
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    width: auto;
  }

  .submit-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #11131e;
    color: #ffffff;
    border: 1px solid rgba(26, 90, 233, 0.4);
    border-radius: 12px;
    padding: 12px 36px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  }

  .submit-button:hover {
    background: #1a5ae9;
    border-color: #1a5ae9;
    box-shadow: 0 4px 20px rgba(26, 90, 233, 0.5);
    transform: translateY(-2px);
  }

  .submit-button:active {
    transform: translateY(0);
  }

  .send-icon {
    transition: transform 0.3s ease;
  }

  .submit-button:hover .send-icon {
    transform: translate(2px, -2px);
  }

  /* Estilos para el QR de CV */
  .qr-code-wrapper {
    grid-area: qr;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    justify-self: center;
  }

  .qr-code-container {
    background: #05010d;
    border: 1px solid rgba(26, 90, 233, 0.3);
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), 0 0 15px rgba(26, 90, 233, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .qr-code-container:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 0 25px rgba(26, 90, 233, 0.3);
    border-color: #1a5ae9;
  }

  .qr-image {
    width: 140px;
    height: 140px;
    display: block;
    border-radius: 8px;
  }

  .qr-label {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Estilos para los botones laterales */
  .buttons-wrapper {
    grid-area: buttons;
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    max-width: 280px;
    justify-self: center;
  }

  @media (max-width: 900px) {
    section {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas:
        "title"
        "form"
        "qr"
        "buttons";
      gap: 35px;
      padding: 60px 15px;
    }

    .form-wrapper {
      max-width: 100%;
    }

    .buttons-wrapper {
      flex-direction: row;
      max-width: 480px;
      justify-content: center;
    }
  }

  @media (max-width: 500px) {
    .buttons-wrapper {
      flex-direction: column;
      max-width: 100%;
    }
    
    .contact-form {
      padding: 2.5rem 1.5rem 6rem 1.5rem;
    }
  }
</style>

