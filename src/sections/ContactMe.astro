---
import Button from "@/components/Button.astro";
import Form from "@/components/Form.astro";
import { Linkedin, Github } from "@lucide/astro";
---

<section>
  <h2 class="title">Contact Me</h2>

  <div class="form-wrapper">
    <Form />
  </div>

  <div class="qr-code-wrapper">
    <div class="qr-code-container">
      <img
        src="https://api.qrserver.com/v1/create-qr-code/?size=160x160&color=ffffff&bgcolor=05010d&data=https://github.com/Gouseppe/portfolio/raw/main/public/Fernando_Guzman.pdf"
        alt="QR Code to view resume"
        class="qr-image"
      />
    </div>
    <div class="qr-label">Escanealo para ver mi CV</div>
  </div>

  <div class="buttons-wrapper">
    <Button
      text="LinkedIn"
      iconPosition="right"
      link="https://www.linkedin.com/in/fernando-guzm%C3%A1n-18177b313/"
      ariaLabel="Boton de linkedin"
      width="100%"
    >
      <Linkedin size={24} width={24} />
    </Button>
    <Button
      text="GitHub"
      iconPosition="left"
      link="https://github.com/Gouseppe"
      ariaLabel="Boton de github"
      width="100%"
    >
      <Github size={24} width={24} />
    </Button>
  </div>
</section>

<style>
  section {
    width: 100%;
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    grid-template-areas:
      "title title"
      "form  qr"
      "form  buttons";
    gap: 40px;
    padding: 80px 20px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    font-size: var(--font-base);
    font-family: system-ui, sans-serif;
  }

  .title {
    grid-area: title;
    font-size: var(--font-title);
    font-weight: 700;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .form-wrapper {
    grid-area: form;
    position: relative;
    width: 480px; /* Ancho exacto y fijo en escritorio */
    margin: 0 auto;
  }

  /* Estilos para el QR de CV con efectos metal-glass de las cards */
  .qr-code-wrapper {
    grid-area: qr;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    justify-self: center;
  }

  .qr-code-container {
    background: rgba(0, 0, 0, 0.247); /* Transparente igual que las cards */
    backdrop-filter: blur(4px);
    border: 1px solid rgba(56, 56, 56, 0.3);
    border-radius: 16px;
    padding: 16px;
    box-shadow:
      0 4px 2px rgba(0, 0, 0, 0.1),
      inset 0 1px 0 rgba(68, 68, 68, 0.5),
      inset 0 -1px 0 rgba(255, 255, 255, 0.1),
      inset 0 0 20px -10px rgb(155, 155, 155);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .qr-code-container:hover {
    transform: scale(1.05);
    /* box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.6),
      0 0 25px rgba(26, 90, 233, 0.3); */
  }

  .qr-image {
    width: 140px;
    height: 140px;
    display: block;
    border-radius: 8px;
  }

  .qr-label {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Estilos para los botones laterales */
  .buttons-wrapper {
    grid-area: buttons;
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    justify-self: center;
  }

  @media (max-width: 900px) {
    section {
      grid-template-columns: minmax(0, 1fr);
      grid-template-areas:
        "title"
        "form"
        "qr"
        "buttons";
      gap: 35px;
      padding: 60px 15px;
    }

    .buttons-wrapper {
      flex-direction: row;
      max-width: 480px;
      justify-content: center;
    }
  }

  @media (max-width: 500px) {
    .buttons-wrapper {
      flex-direction: column;
      max-width: 100%;
    }

    .contact-form {
      padding: 2.5rem 1.5rem 6rem 1.5rem;
    }
  }
</style>
